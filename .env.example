# Agent Memory Benchmarker — Environment Variables
# Copy this file to .env and fill in your keys.
# If API keys are absent the demo runs in mock/dry-run mode automatically.

# ── LLM API Keys ────────────────────────────────────────────────────────────
# OpenRouter API key — recommended; gives access to all models listed below
OPENROUTER_API_KEY=

# Anthropic API key — used for Claude-powered tasks and Mem0 LLM backend
ANTHROPIC_API_KEY=

# OpenAI API key — used for GPT-based models and Mem0 embeddings
OPENAI_API_KEY=

# ── Model Selection ──────────────────────────────────────────────────────────
# Default model for benchmark runs (stored in run metadata; affects Mem0 backend)
# Newest OpenRouter models (2026-03):
#   openai/gpt-5.4-mini         (recommended — fast, affordable)
#   openai/gpt-5.4-nano         (cheapest)
#   openai/gpt-5.4              (high quality)
#   openai/gpt-5.4-pro          (premium)
#   mistralai/mistral-small-2603
#   x-ai/grok-4.20-beta
#   minimax/minimax-m2.7
#   nvidia/nemotron-3-super-120b-a12b:free  (free tier)
BENCHMARK_MODEL=openai/gpt-5.4-mini

# ── Benchmark Tuning ────────────────────────────────────────────────────────
# Number of top-k memories to retrieve per query (default: 3)
BENCHMARK_TOP_K=3

# Default profile: quick | vector | standard | full
BENCHMARK_PROFILE=standard

# Retry configuration for API calls
BENCHMARK_RETRY_ATTEMPTS=3
BENCHMARK_RETRY_BASE_DELAY=1.0

# Memory staleness half-life in seconds (default: 3600 = 1 hour)
MEMORY_DECAY_HALFLIFE=3600

# ── Output Paths ─────────────────────────────────────────────────────────────
# Directory where all output files (charts, CSV, PDF, DB) are saved
BENCHMARK_OUTPUT_DIR=outputs

# ── Gradio Dashboard ─────────────────────────────────────────────────────────
# Host and port for the Gradio UI server
GRADIO_HOST=127.0.0.1
GRADIO_PORT=7860
# Set to "true" to create a public Gradio share link
GRADIO_SHARE=false

# ── Mem0 Configuration ───────────────────────────────────────────────────────
# Mem0 API key (optional — only needed for Mem0 cloud features)
MEM0_API_KEY=
# Override Mem0's internal LLM model (defaults to BENCHMARK_MODEL)
MEM0_LLM_MODEL=openai/gpt-5.4-mini
# Override Mem0's embedding model (default: text-embedding-ada-002)
MEM0_EMBED_MODEL=text-embedding-ada-002
# User ID used when storing/retrieving memories in Mem0 (default: benchmark_user)
MEM0_USER_ID=benchmark_user
# ChromaDB collection name used by the Mem0 backend (default: mem0_benchmark)
MEM0_COLLECTION_NAME=mem0_benchmark
# Local path where Mem0's internal ChromaDB persists data (default: /tmp/mem0_chroma)
MEM0_CHROMA_PATH=/tmp/mem0_chroma
